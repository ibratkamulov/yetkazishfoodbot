{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@common/*": ["src/common/*"],
      "@user/*": ["src/user/*"],
      "@product/*": ["src/product/*"],
      "@order/*": ["src/order/*"],
      "@cart/*": ["src/cart/*"],
      "@payment/*": ["src/payment/*"],
      "@admin/*": ["src/admin/*"]
    }
  },
  "include": ["src"],               // <-- faqat src/ papkasi
  "exclude": ["node_modules", "dist", "prisma", "test"]  // <-- prisma chiqarib tashlandi
}